# ── App ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://snipurl.click
NEXT_PUBLIC_APP_NAME="Snip"

# ── Clerk ────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=   # From Clerk dashboard
CLERK_SECRET_KEY=                    # From Clerk dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard
CLERK_WEBHOOK_SECRET=                # From Clerk dashboard (Svix signing secret)

# ── CockroachDB ──────────────────────────────────────────
DATABASE_URL=          # postgresql://user:pass@host/db?sslmode=verify-full

# ── Analytics / Security ─────────────────────────────────
IP_HASH_SALT=          # Random string; used to hash IPs before storing
